# ===== Local DB (Docker Postgres) =====
DB_HOST=localhost
DB_PORT=5433
DB_NAME=ukrokultur
DB_USER=ukro
DB_PASSWORD=ukro_pass

# ===== Admins (CHANGE BEFORE PROD) =====
ADMIN1_EMAIL=admin1@example.com
ADMIN1_PASSWORD=change_me
ADMIN2_EMAIL=admin2@example.com
ADMIN2_PASSWORD=change_me

# ===== Supabase (set after you create project) =====
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_BUCKET=ukrokultur
SUPABASE_PUBLIC_BASE_URL= # optional, can be empty


# --- hCaptcha (backend secret) ---
HCAPTCHA_ENABLED=true
HCAPTCHA_SECRET=PASTE_HERE

# ===== Contact mail (Resend) =====
CONTACT_MAIL_TO=PASTE_RECEIVER_EMAIL_HERE
RESEND_API_KEY=PASTE_RESEND_API_KEY_HERE
RESEND_FROM=no-reply@YOUR_DOMAIN

# JWT (HMAC) - must be at least 32 chars
JWT_SECRET=CHANGE_ME_CHANGE_ME_CHANGE_ME_32CHARS
JWT_EXPIRES_MINUTES=120
JWT_ISSUER=ukrokultur-api

# ===== Proxy headers (ONLY if behind trusted proxy) =====
FORWARD_HEADERS_STRATEGY=none

# ===== Swagger (enable in dev only) =====
SWAGGER_ENABLED=false